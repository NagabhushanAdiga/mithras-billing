PORT=4000
NODE_ENV=development

# MongoDB connection (local or Atlas)
# Local: mongodb://127.0.0.1:27017/billing
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/billing?retryWrites=true&w=majority
# Note: encode special characters in the password (e.g. @ becomes %40)
MONGODB_URI=mongodb://127.0.0.1:27017/billing

# Change in production
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Comma-separated origins for CORS
CORS_ORIGIN=http://localhost:5173

# First admin account (created on npm run db:reset)
INITIAL_ADMIN_USERNAME=naga
INITIAL_ADMIN_PASSWORD=12345
INITIAL_ADMIN_NAME=Naga
